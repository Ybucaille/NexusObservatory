# Backend
NEXUS_API_HOST=127.0.0.1
NEXUS_API_PORT=8000
NEXUS_DATABASE_PATH=apps/api/nexus_observatory.db

# Multi-endpoint custom provider mode.
# API keys remain backend-only and are never returned to the frontend.
# Example:
# CUSTOM_ENDPOINTS_JSON='[{"id":"openai","label":"OpenAI","base_url":"https://api.openai.com/v1","api_key":"","default_model":"gpt-4o-mini"},{"id":"vllm-local","label":"Local vLLM","base_url":"http://localhost:8001/v1","api_key":"","default_model":"llama3.1"},{"id":"ollama","label":"Ollama","base_url":"http://localhost:11434/v1","api_key":"","default_model":"llama3.1"}]'
CUSTOM_ENDPOINTS_JSON=

# Simple single-endpoint mode. Used when CUSTOM_ENDPOINTS_JSON is empty.
CUSTOM_ENDPOINT_BASE_URL=
CUSTOM_ENDPOINT_API_KEY=
CUSTOM_ENDPOINT_DEFAULT_MODEL=gpt-4o-mini

# Secret storage defaults to auto:
# 1. OS keyring when available.
# 2. Encrypted local fallback under the backend data directory.
NEXUS_SECRET_STORE=auto

# Advanced/dev last resort only. Do not use with real credentials.
# NEXUS_SECRET_STORE=insecure-development
NEXUS_ALLOW_INSECURE_LOCAL_SECRETS=false

# Legacy fallback variables are still supported by the backend if the
# CUSTOM_ENDPOINT_* variables above are empty.
# OPENAI_COMPATIBLE_BASE_URL=
# OPENAI_COMPATIBLE_API_KEY=
# OPENAI_COMPATIBLE_DEFAULT_MODEL=

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
